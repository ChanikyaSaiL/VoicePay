<?xml version="1.0" encoding="UTF-8"?>
<workflow>
    <metadata>
        <name>VoicePay End-to-End Workflow</name>
        <description>Complete workflow process for VoicePay voice authentication and payment system</description>
        <version>1.0</version>
        <created>2026-03-16</created>
    </metadata>

    <phases>
        <!-- PHASE 1: AUTHENTICATION -->
        <phase id="phase-1" name="Authentication">
            <description>User login/registration phase</description>
            <steps>
                <step id="step-1.1" name="Navigate to Auth Page">
                    <description>User accesses /auth route</description>
                    <component>Frontend - Auth.jsx</component>
                    <action>Display login/signup form</action>
                </step>
                <step id="step-1.2" name="User Registration">
                    <description>New user enters credentials</description>
                    <component>Frontend - Auth.jsx</component>
                    <input>Email, Password, Name</input>
                    <endpoint>POST /api/auth/register</endpoint>
                </step>
                <step id="step-1.3" name="Password Hashing">
                    <description>Hash password using bcryptjs</description>
                    <component>Backend - auth.js</component>
                    <processing>bcryptjs.hash(password, 10)</processing>
                </step>
                <step id="step-1.4" name="Store User in Database">
                    <description>Save user record to MongoDB</description>
                    <component>Backend - User Model</component>
                    <database>MongoDB - Users Collection</database>
                    <fields>email, password (hashed), name, hasVoiceEnrolled (false)</fields>
                </step>
                <step id="step-1.5" name="Generate JWT Token">
                    <description>Create authentication token</description>
                    <component>Backend - auth.js</component>
                    <processing>jwt.sign() with secret key</processing>
                </step>
                <step id="step-1.6" name="Set Session Cookie">
                    <description>Store token in HTTP-only cookie</description>
                    <component>Backend - auth.js</component>
                    <security>HTTP-only, Secure flag enabled</security>
                </step>
                <step id="step-1.7" name="Redirect to Enrollment">
                    <description>Authenticated but not enrolled users redirected</description>
                    <component>Frontend - App.jsx</component>
                    <condition>isAuthenticated && !isEnrolled → Navigate to /enroll</condition>
                </step>
            </steps>
        </phase>

        <!-- PHASE 2: VOICE ENROLLMENT -->
        <phase id="phase-2" name="Voice Enrollment" depends-on="phase-1">
            <description>User voice recording and enrollment phase</description>
            <steps>
                <step id="step-2.1" name="Access Enrollment Page">
                    <description>Navigate to enrollment page</description>
                    <component>Frontend - Enrollment.jsx</component>
                    <route>/enroll</route>
                </step>
                <step id="step-2.2" name="Request Microphone Permission">
                    <description>Browser requests user permission for audio</description>
                    <component>Frontend - useSpeechRecognition hook</component>
                    <api>navigator.mediaDevices.getUserMedia()</api>
                </step>
                <step id="step-2.3" name="Record Voice Sample 1">
                    <description>User records first voice sample</description>
                    <component>Frontend - Enrollment.jsx</component>
                    <input>Audio stream from microphone</input>
                    <format>WAV/WebM</format>
                </step>
                <step id="step-2.4" name="Record Voice Sample 2">
                    <description>User records second voice sample</description>
                    <component>Frontend - Enrollment.jsx</component>
                    <input>Audio stream from microphone</input>
                    <format>WAV/WebM</format>
                </step>
                <step id="step-2.5" name="Record Voice Sample 3">
                    <description>User records third voice sample</description>
                    <component>Frontend - Enrollment.jsx</component>
                    <input>Audio stream from microphone</input>
                    <format>WAV/WebM</format>
                </step>
                <step id="step-2.6" name="Convert Audio to 16kHz Format">
                    <description>Convert audio samples to standardized format</description>
                    <component>Backend - voiceVerify.js</component>
                    <processing>ffmpeg: Convert to 16kHz mono WAV</processing>
                    <output>Float32Array at 16kHz sample rate</output>
                </step>
                <step id="step-2.7" name="Generate Voice Embedding">
                    <description>Extract voice characteristics using ML model</description>
                    <component>Backend - voiceVerify.js</component>
                    <model>Face Recognition Model (adapted for voice)</model>
                    <output>Voice embedding vector (high-dimensional array)</output>
                </step>
                <step id="step-2.8" name="Store Voice Embedding">
                    <description>Save voice embedding to database</description>
                    <component>Backend - User Model</component>
                    <database>MongoDB - Users Collection</database>
                    <fields>voiceEmbedding (array), hasVoiceEnrolled (true)</fields>
                </step>
                <step id="step-2.9" name="Enrollment Success">
                    <description>User enrollment completed</description>
                    <component>Frontend - Enrollment.jsx</component>
                    <action>Redirect to /setup or Home page</action>
                </step>
            </steps>
        </phase>

        <!-- PHASE 3: SETUP & CONFIGURATION -->
        <phase id="phase-3" name="Setup & Configuration" depends-on="phase-2">
            <description>User account setup and configuration</description>
            <steps>
                <step id="step-3.1" name="Access Setup Page">
                    <description>Navigate to setup/configuration page</description>
                    <component>Frontend - Setup.jsx</component>
                    <route>/setup</route>
                </step>
                <step id="step-3.2" name="Configure Payment Settings">
                    <description>User configures payment methods and preferences</description>
                    <component>Frontend - Setup.jsx</component>
                    <input>Recipient names, payment limits, preferences</input>
                </step>
                <step id="step-3.3" name="Enable Two-Factor Options">
                    <description>Setup voice verification as 2FA option</description>
                    <component>Frontend - Setup.jsx</component>
                    <configuration>Voice verification enabled</configuration>
                </step>
                <step id="step-3.4" name="Save Configuration">
                    <description>Persist user settings to database</description>
                    <component>Backend - User Model</component>
                    <database>MongoDB - Users Collection</database>
                </step>
            </steps>
        </phase>

        <!-- PHASE 4: HOME/DASHBOARD -->
        <phase id="phase-4" name="Home & Dashboard" depends-on="phase-2">
            <description>User dashboard and main interface</description>
            <steps>
                <step id="step-4.1" name="Access Home Page">
                    <description>Navigate to home/dashboard</description>
                    <component>Frontend - Home.jsx</component>
                    <route>/</route>
                </step>
                <step id="step-4.2" name="Fetch User Balance">
                    <description>Retrieve user's current wallet balance</description>
                    <component>Backend - auth.js</component>
                    <endpoint>GET /api/auth/me</endpoint>
                    <data>balance, transactions, hasEnrolled flag</data>
                </step>
                <step id="step-4.3" name="Display Transaction History">
                    <description>Show recent transactions on dashboard</description>
                    <component>Frontend - Home.jsx</component>
                    <data>Recipient name, amount, type (sent/received), date</data>
                </step>
                <step id="step-4.4" name="Access Analytics Page">
                    <description>Optional: View detailed transaction analytics</description>
                    <component>Frontend - Analytics.jsx</component>
                    <route>/analytics</route>
                    <data>Monthly spending, transaction patterns, trends</data>
                </step>
            </steps>
        </phase>

        <!-- PHASE 5: PAYMENT AUTHENTICATION -->
        <phase id="phase-5" name="Payment Authentication" depends-on="phase-2">
            <description>Voice verification for payment authorization</description>
            <steps>
                <step id="step-5.1" name="Initiate Payment">
                    <description>User clicks Pay or Payment Auth button</description>
                    <component>Frontend - Home.jsx or PaymentAuth.jsx</component>
                    <action>Open payment authorization modal</action>
                </step>
                <step id="step-5.2" name="Navigate to Payment Auth Page">
                    <description>User redirected to payment authorization page</description>
                    <component>Frontend - PaymentAuth.jsx</component>
                    <route>/payment-auth</route>
                </step>
                <step id="step-5.3" name="Display Payment Prompt">
                    <description>Show recipient and amount to verify</description>
                    <component>Frontend - PaymentAuth.jsx</component>
                    <data>Recipient name, Amount, Voice verification required message</data>
                </step>
                <step id="step-5.4" name="Request Voice Sample">
                    <description>Prompt user to record voice for verification</description>
                    <component>Frontend - VoiceOverlay.jsx</component>
                    <action>Display microphone icon and recording UI</action>
                </step>
                <step id="step-5.5" name="Record Authorization Voice">
                    <description>User says confirmation phrase (e.g., "Authorize Payment")</description>
                    <component>Frontend - useSpeechRecognition hook</component>
                    <input>Audio stream from microphone</input>
                </step>
                <step id="step-5.6" name="Convert Voice Sample">
                    <description>Convert recorded audio to standardized format</description>
                    <component>Backend - voiceVerify.js</component>
                    <processing>ffmpeg: Convert to 16kHz mono WAV</processing>
                    <output>Float32Array at 16kHz sample rate</output>
                </step>
                <step id="step-5.7" name="Generate Voice Embedding">
                    <description>Extract voice characteristics from verification sample</description>
                    <component>Backend - voiceVerify.js</component>
                    <model>Face Recognition Model (adapted for voice)</model>
                    <output>Voice embedding vector</output>
                </step>
                <step id="step-5.8" name="Compare Voice Embeddings">
                    <description>Compare current voice with enrolled voice profile</description>
                    <component>Backend - voiceVerify.js</component>
                    <algorithm>Euclidean distance / Cosine similarity</algorithm>
                    <threshold>Match threshold (e.g., distance &lt; 0.6)</threshold>
                </step>
                <step id="step-5.9" name="Verify Speech Recognition">
                    <description>Verify spoken phrase matches expected authorization phrase</description>
                    <component>Backend - voiceVerify.js</component>
                    <processing>Speech-to-text recognition check</processing>
                </step>
                <step id="step-5.10" name="Voice Verification Result">
                    <description>Determine if voice verification passed or failed</description>
                    <component>Backend - voiceVerify.js</component>
                    <output>Pass/Fail with confidence score</output>
                </step>
                <step id="step-5.11" name="Authentication Failed (if applicable)">
                    <description>Return error if verification failed</description>
                    <component>Frontend - PaymentAuth.jsx</component>
                    <condition>IF voice match confidence &lt; threshold</condition>
                    <action>Display "Voice verification failed" message, allow retry</action>
                </step>
            </steps>
        </phase>

        <!-- PHASE 6: PAYMENT PROCESSING -->
        <phase id="phase-6" name="Payment Processing" depends-on="phase-5">
            <description>Process and execute payment transaction</description>
            <steps>
                <step id="step-6.1" name="Voice Verification Success">
                    <description>Voice authentication confirmed</description>
                    <component>Backend - voiceVerify.js</component>
                    <condition>Voice embeddings match &gt; threshold</condition>
                </step>
                <step id="step-6.2" name="Extract Payment Details">
                    <description>Retrieve payment amount, recipient, and user info</description>
                    <component>Backend - payment.js</component>
                    <data>email, amount, recipientName</data>
                </step>
                <step id="step-6.3" name="Fetch User Account">
                    <description>Retrieve user from database</description>
                    <component>Backend - User Model</component>
                    <database>MongoDB - Users Collection</database>
                </step>
                <step id="step-6.4" name="Validate Sufficient Balance">
                    <description>Check if user has enough balance for payment</description>
                    <component>Backend - payment.js</component>
                    <condition>IF balance &lt; payment amount THEN reject</condition>
                </step>
                <step id="step-6.5" name="Insufficient Balance Error (if applicable)">
                    <description>Return error if balance insufficient</description>
                    <component>Frontend - PaymentAuth.jsx</component>
                    <action>Display "Insufficient wallet balance" error message</action>
                </step>
                <step id="step-6.6" name="Deduct Payment Amount">
                    <description>Subtract payment amount from user balance</description>
                    <component>Backend - payment.js</component>
                    <calculation>user.balance -= paymentAmount</calculation>
                </step>
                <step id="step-6.7" name="Create Transaction Record">
                    <description>Log transaction details</description>
                    <component>Backend - payment.js</component>
                    <transaction>
                        <field>recipientName</field>
                        <field>amount</field>
                        <field>type: "sent"</field>
                        <field>initial (recipient initials)</field>
                        <field>date: current timestamp</field>
                    </transaction>
                </step>
                <step id="step-6.8" name="Store Transaction in Database">
                    <description>Save updated balance and transaction record</description>
                    <component>Backend - User Model</component>
                    <database>MongoDB - Users Collection</database>
                    <operation>user.save()</operation>
                </step>
                <step id="step-6.9" name="Payment Success Response">
                    <description>Send success response with new balance</description>
                    <component>Backend - payment.js</component>
                    <data>message, newBalance, transaction details</data>
                </step>
                <step id="step-6.10" name="Display Payment Confirmation">
                    <description>Show payment success to user</description>
                    <component>Frontend - PaymentAuth.jsx</component>
                    <display>Confirmation message, new balance, receipt</display>
                </step>
                <step id="step-6.11" name="Update Dashboard">
                    <description>Refresh transaction history on home page</description>
                    <component>Frontend - Home.jsx</component>
                    <action>Fetch updated balance and transactions</action>
                </step>
                <step id="step-6.12" name="Return to Home</step>
                    <description>User returns to dashboard after payment</description>
                    <component>Frontend - Home.jsx</component>
                    <route>/</route>
                </step>
            </steps>
        </phase>

        <!-- PHASE 7: SESSION MANAGEMENT -->
        <phase id="phase-7" name="Session Management" depends-on="phase-1">
            <description>User session maintenance and logout</description>
            <steps>
                <step id="step-7.1" name="Maintain Session">
                    <description>JWT token stored in HTTP-only cookie</description>
                    <component>Backend - auth.js</component>
                    <persistence>Browser automatically sends cookie with requests</persistence>
                </step>
                <step id="step-7.2" name="Restore Session on App Load">
                    <description>Check for valid session on app initialization</description>
                    <component>Frontend - AuthContext.jsx</component>
                    <endpoint>GET /api/auth/me</endpoint>
                    <action>Verify token and restore user session</action>
                </step>
                <step id="step-7.3" name="User Logout">
                    <description>User clicks logout button</description>
                    <component>Frontend - Layout.jsx or Auth.jsx</component>
                    <action>Clear session and redirect to auth</action>
                </step>
                <step id="step-7.4" name="Clear Server Session">
                    <description>Invalidate JWT token on server</description>
                    <component>Backend - auth.js</component>
                    <endpoint>POST /api/auth/logout</endpoint>
                </step>
                <step id="step-7.5" name="Clear Client Session">
                    <description>Remove token from client storage</description>
                    <component>Frontend - AuthContext.jsx</component>
                    <action>Clear auth state and redirect to /auth</action>
                </step>
            </steps>
        </phase>
    </phases>

    <!-- DATA FLOW -->
    <data-flow>
        <entity name="User">
            <attributes>
                <attribute name="email" type="string" required="true"/>
                <attribute name="password" type="string (hashed)" required="true"/>
                <attribute name="name" type="string" required="true"/>
                <attribute name="balance" type="number" default="random(20000-80000)"/>
                <attribute name="voiceEmbedding" type="array" description="High-dimensional voice characteristics vector"/>
                <attribute name="hasVoiceEnrolled" type="boolean" default="false"/>
                <attribute name="hasEnrolled" type="boolean" default="false"/>
                <attribute name="transactions" type="array" description="Transaction history"/>
                <attribute name="createdAt" type="timestamp"/>
            </attributes>
        </entity>
        <entity name="Transaction">
            <attributes>
                <attribute name="recipientName" type="string"/>
                <attribute name="amount" type="number"/>
                <attribute name="type" type="enum" values="sent,received"/>
                <attribute name="initial" type="string" description="Recipient initials for avatar"/>
                <attribute name="date" type="timestamp"/>
            </attributes>
        </entity>
    </data-flow>

    <!-- API ENDPOINTS -->
    <api-endpoints>
        <!-- Authentication Endpoints -->
        <endpoint method="POST" path="/api/auth/register" description="Register new user">
            <request>email, password, name</request>
            <response>token, user</response>
        </endpoint>
        <endpoint method="POST" path="/api/auth/login" description="Login existing user">
            <request>email, password</request>
            <response>token, user</response>
        </endpoint>
        <endpoint method="GET" path="/api/auth/me" description="Get current user session">
            <request>Requires JWT token in cookie</request>
            <response>user with balance, transactions, hasEnrolled flag</response>
        </endpoint>
        <endpoint method="POST" path="/api/auth/logout" description="Logout user">
            <response>success message</response>
        </endpoint>

        <!-- Voice Verification Endpoints -->
        <endpoint method="POST" path="/api/voice/enroll" description="Enroll user voice samples">
            <request>email, multiple audio files</request>
            <response>success, voice embedding saved</response>
        </endpoint>
        <endpoint method="POST" path="/api/voice/verify" description="Verify voice for payment">
            <request>email, audio file</request>
            <response>match confidence score, pass/fail</response>
        </endpoint>

        <!-- Payment Endpoints -->
        <endpoint method="POST" path="/api/payment/process" description="Process payment transaction">
            <request>email, amount, recipientName</request>
            <response>success, newBalance, transaction details</response>
        </endpoint>

        <!-- Analytics Endpoints -->
        <endpoint method="GET" path="/api/speech/analytics" description="Get transaction analytics">
            <request>email, optional date range</request>
            <response>transaction trends, spending patterns</response>
        </endpoint>
    </api-endpoints>

    <!-- KEY COMPONENTS -->
    <components>
        <frontend>
            <component name="Auth.jsx" description="Login/Registration page"/>
            <component name="Home.jsx" description="Dashboard with balance and transactions"/>
            <component name="Enrollment.jsx" description="Voice enrollment interface"/>
            <component name="Setup.jsx" description="Account setup and configuration"/>
            <component name="PaymentAuth.jsx" description="Payment authorization with voice verification"/>
            <component name="Analytics.jsx" description="Transaction analytics and history"/>
            <component name="Layout.jsx" description="Main layout wrapper with navigation"/>
            <component name="VoiceOverlay.jsx" description="Voice recording overlay interface"/>
            <component name="AuthContext.jsx" description="Global authentication state management"/>
        </frontend>
        <backend>
            <component name="server.js" description="Express.js server setup"/>
            <component name="routes/auth.js" description="Authentication route handlers"/>
            <component name="routes/payment.js" description="Payment processing handlers"/>
            <component name="routes/voiceVerify.js" description="Voice verification and ML processing"/>
            <component name="routes/speech.js" description="Speech recognition handlers"/>
            <component name="routes/verify.js" description="General verification handlers"/>
            <component name="models/User.js" description="MongoDB User schema"/>
        </backend>
        <ml-models>
            <model name="tiny_face_detector_model" description="Face detection for video/image analysis"/>
            <model name="face_landmark_68_model" description="68-point facial landmark detection"/>
            <model name="face_recognition_model" description="Facial recognition engine (adapted for voice embeddings)"/>
        </ml-models>
    </components>

    <!-- SECURITY MEASURES -->
    <security>
        <measure id="sec-1" name="Password Hashing">
            <description>All passwords hashed using bcryptjs with salt rounds = 10</description>
            <implementation>Backend - auth.js</implementation>
        </measure>
        <measure id="sec-2" name="JWT Authentication">
            <description>Stateless authentication using JWT tokens</description>
            <implementation>Backend - auth.js</implementation>
        </measure>
        <measure id="sec-3" name="HTTP-Only Cookies">
            <description>JWT tokens stored in HTTP-only cookies to prevent XSS attacks</description>
            <implementation>Backend - auth.js</implementation>
        </measure>
        <measure id="sec-4" name="CORS Configuration">
            <description>Cross-Origin Resource Sharing configured on backend</description>
            <implementation>Backend - server.js</implementation>
        </measure>
        <measure id="sec-5" name="Voice Biometric Security">
            <description>Voice embeddings compared with cosine similarity/Euclidean distance</description>
            <implementation>Backend - voiceVerify.js</implementation>
        </measure>
        <measure id="sec-6" name="Audio Standardization">
            <description>All voice samples converted to 16kHz mono format for consistency</description>
            <implementation>Backend - voiceVerify.js</implementation>
        </measure>
        <measure id="sec-7" name="MongoDB Connection">
            <description>Secure MongoDB connection with URI from environment variables</description>
            <implementation>Backend - server.js</implementation>
        </measure>
    </security>

    <!-- ERROR HANDLING -->
    <error-handling>
        <error code="AUTH_001" name="Invalid Credentials">
            <trigger>User enters wrong password or non-existent email</trigger>
            <response>Return 401 Unauthorized with generic message</response>
        </error>
        <error code="AUTH_002" name="User Already Exists">
            <trigger>Registration attempt with existing email</trigger>
            <response>Return 400 Bad Request</response>
        </error>
        <error code="VOICE_001" name="Voice Verification Failed">
            <trigger>Voice embedding distance exceeds threshold</trigger>
            <response>Return 401 Unauthorized, allow retry</response>
        </error>
        <error code="PAYMENT_001" name="Insufficient Balance">
            <trigger>Payment amount exceeds user balance</trigger>
            <response>Return 400 Bad Request with balance info</response>
        </error>
        <error code="PAYMENT_002" name="Invalid Payment Amount">
            <trigger>Payment amount is zero or negative</trigger>
            <response>Return 400 Bad Request</response>
        </error>
        <error code="AUDIO_001" name="Audio Conversion Failed">
            <trigger>FFmpeg fails to convert audio file</trigger>
            <response>Return 500 Internal Server Error with cleanup</response>
        </error>
        <error code="DB_001" name="MongoDB Connection Failed">
            <trigger>Cannot connect to MongoDB database</trigger>
            <response>Log error and exit process</response>
        </error>
    </error-handling>

    <!-- DECISION POINTS -->
    <decision-points>
        <decision id="dec-1" name="User Authenticated?">
            <options>
                <option id="opt-1" value="Yes">Proceed to enrollment check</option>
                <option id="opt-2" value="No">Redirect to /auth</option>
            </options>
        </decision>
        <decision id="dec-2" name="User Enrolled?">
            <options>
                <option id="opt-1" value="Yes">Redirect to Home (/)</option>
                <option id="opt-2" value="No">Redirect to Enrollment (/enroll)</option>
            </options>
        </decision>
        <decision id="dec-3" name="Voice Verification Matches?">
            <options>
                <option id="opt-1" value="Yes">Proceed to payment processing</option>
                <option id="opt-2" value="No">Display error, allow retry</option>
            </options>
        </decision>
        <decision id="dec-4" name="Sufficient Balance?">
            <options>
                <option id="opt-1" value="Yes">Process payment</option>
                <option id="opt-2" value="No">Display error, prevent payment</option>
            </options>
        </decision>
    </decision-points>

</workflow>
