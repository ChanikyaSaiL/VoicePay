# ----------------------------------------------------
# VoicePay Backend Configuration Keys 
# ----------------------------------------------------
# 
# Please duplicate this file and rename the copy to:
# .env
# 
# Provide the following keys inside the new `.env` file!

# 1. MongoDB Atlas URI
#    Get this by creating a free cluster on cloud.mongodb.com
#    Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/voicepay?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/voicepay

# 2. JSON Web Token Secret
#    This is used to cryptographically sign user sessions (login cookies/tokens)
#    You can generate a random string, typically a 64-character hex string.
#    E.g. run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=your_super_secret_jwt_key_here

# 3. Server Port
#    By default, the backend will run on port 5000, Vite frontend on 5173.
PORT=5000

# NOTE: The Voice / Face embeddings will be stored as arrays directly inside MongoDB!
